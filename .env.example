# MOUBARIK Parking - Djibouti
# Copiez en .env et configurez l'URL de l'API WAMP

# URL de l'API PHP (WAMP)
# Si le projet est dans C:\wamp64\www\parking-intelligent\
VITE_API_URL=http://localhost/parking-intelligent/api

# Ou avec un espace dans le nom du dossier :
# VITE_API_URL=http://localhost/parking%20intelligent/api
